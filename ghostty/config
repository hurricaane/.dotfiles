# Dynamic theme color
config-file = ?"~/.config/omarchy/current/theme/ghostty.conf"
# Font
font-family = "CaskaydiaCove Nerd Font"
font-size = 10

# Appearance
# TODO: Check if this is supported on linux
adjust-cell-height = 30%
background-opacity = 0.98
cursor-style = bar
mouse-hide-while-typing = true
window-decoration = false
window-padding-x = 14
window-padding-y = 14
resize-overlay = never
gtk-toolbar-style = flat

# Terminal settings
# shell-integration-features = cursor,sudo,no-title
shell-integration-features = no-cursor,ssh-env,no-title,sudo
term = xterm-256color

# Keybindings
keybind = ctrl+]=reload_config
keybind = f11=toggle_fullscreen
keybind = shift+insert=paste_from_clipboard
keybind = control+insert=copy_to_clipboard
keybind = super+control+shift+alt+arrow_down=resize_split:down,100
keybind = super+control+shift+alt+arrow_up=resize_split:up,100
keybind = super+control+shift+alt+arrow_left=resize_split:left,100
keybind = super+control+shift+alt+arrow_right=resize_split:right,100

# General
command = /usr/bin/fish --login --interactive
confirm-close-surface = false
window-inherit-working-directory = true
keybind = shift+enter=text:\x1b\r

# Slowdown mouse scrolling
mouse-scroll-multiplier = 0.95

# Fix general slowness on hyprland (https://github.com/ghostty-org/ghostty/discussions/3224)
async-backend = epoll
